#!/bin/bash
# Install and configure dotfiles for a fresh macOS setup
set -e

SCRIPT_DIR="$(dirname "${BASH_SOURCE[0]}")/.."
source "$SCRIPT_DIR/lib/logging.sh"

CODE="$HOME/Code"
DOTFILES="$CODE/config/global/dotfiles"

header "Setting up your Mac"

# Create folders
mkdir -p "$CODE"

# Check for Homebrew and install if we don't have it
if ! command -v brew &>/dev/null; then
    step "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    grep -q 'brew shellenv' "$HOME/.zprofile" 2>/dev/null || echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >>"$HOME/.zprofile"
    eval "$(/opt/homebrew/bin/brew shellenv)"
    brew analytics off
    success "Installed"
else
    skip_with_note "Homebrew" "already installed"
fi

# Check for Oh My Zsh and install if we don't have it
if [[ ! -d "$HOME/.oh-my-zsh/" ]]; then
    step "Installing Oh My Zsh..."
    /bin/sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    success "Installed"
else
    skip_with_note "Oh My Zsh" "already installed"
fi

# Symlink shell config
rm -f "$HOME/.zshrc"
ln -swf "$DOTFILES/shell/.zshrc" "$HOME/.zshrc"
success_with_note ".zshrc" "symlinked"

# Install dependencies with Homebrew bundle
step "Installing Homebrew dependencies..."
brew update
brew bundle --file "$DOTFILES/config/Brewfile"
success "Installed"

# Symlink the global git files
mkdir -p "$HOME/.config/git"
ln -swf "$DOTFILES/config/git/config" "$HOME/.gitconfig"
ln -swf "$DOTFILES/config/git/ignore" "$HOME/.config/git/ignore"
ln -swf "$DOTFILES/config/git/hooks" "$HOME/.config/git/hooks"
success_with_note ".gitconfig" "symlinked"
success_with_note ".config/git/ignore" "symlinked"
success_with_note ".config/git/hooks" "symlinked"

# Symlink the Mackup config file to the home directory
# Not using Mackup until https://github.com/lra/mackup?tab=readme-ov-file#warning is resolved
#ln -swf "$DOTFILES/config/.mackup.cfg" "$HOME/.mackup.cfg"
#success_with_note ".mackup.cfg" "symlinked"
#mackup restore

# Optionally set up SSH key for GitHub
echo ""
read -p "Set up SSH key for GitHub? (y/n) " -n 1 -r
echo ""
if [[ $REPLY =~ ^[Yy]$ ]]; then
    source "$DOTFILES/bin/setup-ssh"
fi

# Initialise submodules (requires SSH)
step "Initialising submodules..."
git -C "$DOTFILES" submodule update --init --recursive
success "Initialised"

# Clone config repos
step "Setting up config repos..."
mkdir -p "$CODE/config/global"
if [[ ! -d "$CODE/config/global/claude" ]]; then
    git clone git@github.com:damianlewis/dotclaude.git "$CODE/config/global/claude"
else
    skip_with_note "claude config" "already cloned"
fi
if [[ ! -d "$CODE/config/global/opencode" ]]; then
    git clone git@github.com:damianlewis/dotopencode.git "$CODE/config/global/opencode"
else
    skip_with_note "opencode config" "already cloned"
fi
if [[ ! -d "$CODE/config/global/warp" ]]; then
    git clone git@github.com:damianlewis/dotwarp.git "$CODE/config/global/warp"
else
    skip_with_note "warp config" "already cloned"
fi

# Set up Claude Code config
if [[ -f "$CODE/config/global/claude/bin/install" ]]; then
    source "$CODE/config/global/claude/bin/install"
else
    skip_with_note "Claude Code config" "not found"
fi

# Set up opencode config
if [[ -f "$CODE/config/global/opencode/bin/install" ]]; then
    source "$CODE/config/global/opencode/bin/install"
else
    skip_with_note "opencode config" "not found"
fi

# Set up Warp config
if [[ -f "$CODE/config/global/warp/bin/install" ]]; then
    source "$CODE/config/global/warp/bin/install"
else
    skip_with_note "Warp config" "not found"
fi

# Optionally run work setup
echo ""
read -p "Run work setup? (y/n) " -n 1 -r
echo ""
if [[ $REPLY =~ ^[Yy]$ ]]; then
    source "$DOTFILES/work/bin/setup"
fi

echo ""
success "Done"
detail "You may want to restart your terminal." true
