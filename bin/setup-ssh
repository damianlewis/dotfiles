#!/bin/bash
# Generate and configure an SSH key for GitHub
set -e

SCRIPT_DIR="$(dirname "${BASH_SOURCE[0]}")/.."
source "$SCRIPT_DIR/lib/logging.sh"

header "Setting up SSH for GitHub"

if [[ -n "$1" ]]; then
  email="$1"
else
  read -p "Enter your email: " email
fi

if [[ -z "$email" ]]; then
  error "Email is required"
  return 1 2>/dev/null || exit 1
fi

KEY_NAME="id_ed25519_github"

# Generate a new SSH key
step "Generating SSH key..."
mkdir -p "$HOME/.ssh"
ssh-keygen -t ed25519 -C "$email" -f "$HOME/.ssh/$KEY_NAME"
chmod 600 "$HOME/.ssh/$KEY_NAME"
success "Generated"

# Add SSH key to the ssh-agent
step "Adding key to ssh-agent..."
eval "$(ssh-agent -s)"

if ! grep -q "Host github.com" "$HOME/.ssh/config" 2>/dev/null; then
  cat >> "$HOME/.ssh/config" <<EOF

Host github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/$KEY_NAME
EOF
  success "Updated"
else
  skip_with_note "SSH config" "already has GitHub entry"
fi

ssh-add --apple-use-keychain "$HOME/.ssh/$KEY_NAME"
success "Added to ssh-agent"

# Add SSH key to GitHub account
step "Adding key to GitHub..."
gh auth login
gh ssh-key add "$HOME/.ssh/$KEY_NAME.pub" --title "$(scutil --get ComputerName)"
success "Added to GitHub"
