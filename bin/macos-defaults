#!/bin/bash
# Apply preferred macOS system defaults
set -e

SCRIPT_DIR="$(dirname "${BASH_SOURCE[0]}")/.."
source "$SCRIPT_DIR/lib/logging.sh"

header "Applying macOS defaults"

# Dock
step "Configuring Dock..."
defaults write com.apple.dock mouse-over-hilite-stack -bool true && killall Dock
success "Dock hover effect enabled"

# Save & Print panels
step "Configuring save and print panels..."
defaults write NSGlobalDomain NSNavPanelExpandedStateForSaveMode -bool true
defaults write NSGlobalDomain NSNavPanelExpandedStateForSaveMode2 -bool true
defaults write NSGlobalDomain PMPrintingExpandedStateForPrint -bool true
defaults write NSGlobalDomain PMPrintingExpandedStateForPrint2 -bool true
success "Panels expanded by default"

# iCloud
defaults write NSGlobalDomain NSDocumentSaveNewDocumentsToCloud -bool false
success_with_note "Save to disk by default" "not iCloud"

# .DS_Store
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true
success ".DS_Store disabled on network and USB volumes"

# Time Machine
defaults write com.apple.TimeMachine DoNotOfferNewDisksForBackup -bool true
success "Time Machine new disk prompts disabled"

# Archive file associations — override hijackers (BetterZip etc.)
# Quick Look extension stays registered independently, so previews still work.
if command -v duti &>/dev/null; then
    step "Resetting archive file associations to Archive Utility..."
    duti -s com.apple.archiveutility public.zip-archive all
    duti -s com.apple.archiveutility public.tar-archive all
    duti -s com.apple.archiveutility org.gnu.gnu-zip-archive all
    duti -s com.apple.archiveutility org.7-zip.7-zip-archive all
    duti -s com.apple.archiveutility com.rarlab.rar-archive all
    success "Archive file associations reset"
else
    skip_with_note "Archive file associations" "duti not installed — run 'brew install duti'"
fi

echo ""
success "Done"
detail "Some changes may require a restart to take effect." true
